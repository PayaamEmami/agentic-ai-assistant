# Application
# Optional: app environment mode. Defaults to development.
NODE_ENV=development
# Optional: log verbosity level. Defaults to info.
LOG_LEVEL=debug
# Optional: log output format. Defaults to pretty in development and json otherwise.
LOG_FORMAT=pretty
# Optional: enable writing structured logs to the local .logs directory. Defaults to true outside production.
LOG_FILE_ENABLED=true
# Optional: direct Loki push endpoint for local or hosted log aggregation.
LOG_LOKI_ENDPOINT=http://localhost:3100/loki/api/v1/push
# Optional: Docker log rotation size for the AWS deployment.
DOCKER_LOG_MAX_SIZE=10m
# Optional: Docker log rotation file count for the AWS deployment.
DOCKER_LOG_MAX_FILES=5

# API Server
# Optional: API bind host. Defaults to 0.0.0.0.
API_HOST=0.0.0.0
# Optional: API port. Defaults to 3001.
API_PORT=3001
# Optional: internal API base URL used by the worker for Playwright RPC calls.
INTERNAL_API_BASE_URL=http://localhost:3001
# Required in production: shared secret for internal worker-to-API Playwright RPC authentication.
INTERNAL_SERVICE_SECRET=replace-with-a-strong-internal-secret

# Frontend
# Optional: browser-facing API base URL for the web app.
NEXT_PUBLIC_API_URL=http://localhost:3001
# Optional: dev login email shown in local development.
NEXT_PUBLIC_DEV_AUTH_EMAIL=dev@localhost
# Optional: frontend base URL for OAuth callback redirects. Defaults to http://localhost:3000.
# The AWS deploy script overrides this with the EC2 public URL unless PUBLIC_BASE_URL is set.
WEB_BASE_URL=http://localhost:3000

# PostgreSQL
# Optional: change both of these if 5432 is already in use on your machine.
LOCAL_POSTGRES_PORT=5432
# Required: PostgreSQL connection string.
DATABASE_URL=postgresql://aaa:aaa_dev_password@localhost:5432/aaa
# Optional: PostgreSQL container database name for the AWS deployment.
POSTGRES_DB=aaa
# Optional: PostgreSQL container user for the AWS deployment.
POSTGRES_USER=aaa
# Required for the AWS deployment when DATABASE_URL does not include a password.
POSTGRES_PASSWORD=aaa_dev_password
# Optional: database connection pool size.
DATABASE_POOL_SIZE=10

# Redis
# Optional: change both of these if 6379 is already in use on your machine.
LOCAL_REDIS_PORT=6379
# Optional: Redis connection string. Defaults to redis://localhost:6379.
REDIS_URL=redis://localhost:6379

# Observability
# Optional: local OTLP HTTP port exposed by the collector.
LOCAL_OTEL_HTTP_PORT=4318
# Optional: OTLP endpoint for traces and telemetry export.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Optional: OpenTelemetry service namespace. Defaults to aaa.
OTEL_SERVICE_NAMESPACE=aaa
# Optional: comma-separated OpenTelemetry resource attributes in key=value format.
OTEL_RESOURCE_ATTRIBUTES=
# Optional: worker observability server bind host. Defaults to 0.0.0.0.
WORKER_OBSERVABILITY_HOST=0.0.0.0
# Optional: worker observability server port. Defaults to 9464.
WORKER_OBSERVABILITY_PORT=9464
# Optional: JSON object that overrides default OpenAI pricing used for estimated cost metrics and logs.
OPENAI_PRICING_OVERRIDES_JSON=

# S3 / Object Storage
# Optional: S3 bucket name. Defaults to aaa-uploads.
S3_BUCKET=aaa-uploads
# Optional: S3 region. Defaults to us-west-1.
S3_REGION=us-west-1
# Optional: S3 endpoint override for local MinIO or other S3-compatible storage.
S3_ENDPOINT=http://localhost:9000
# Optional: access key for local S3-compatible storage.
S3_ACCESS_KEY_ID=minioadmin
# Optional: secret key for local S3-compatible storage.
S3_SECRET_ACCESS_KEY=minioadmin

# OpenAI
# Required: OpenAI API key.
OPENAI_API_KEY=sk-your-key-here
# Optional: chat model. Defaults to gpt-5-mini.
OPENAI_MODEL=gpt-5-mini
# Optional: embeddings model. Defaults to text-embedding-3-small.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: realtime speech-to-speech model for live voice mode. Defaults to gpt-realtime-1.5.
OPENAI_REALTIME_MODEL=gpt-realtime-1.5
# Optional: voice preset for live voice mode. Defaults to marin.
OPENAI_REALTIME_VOICE=marin
# Required: JWT signing secret in production. Optional in local dev because the API falls back to a dev secret.
JWT_SECRET=replace-with-a-strong-secret

# Apps
# Optional: GitHub access token for local GitHub work.
GITHUB_TOKEN=ghp_your_github_token_here
# Optional: GitHub OAuth app client ID.
GITHUB_CLIENT_ID=your_github_oauth_client_id
# Optional: GitHub OAuth app client secret.
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
# Optional: GitHub OAuth callback base URL. Register the derived callback URL on the GitHub OAuth app.
# The app will derive:
# - /callback
GITHUB_APP_REDIRECT_URI_BASE=http://localhost:3001/api/apps/github/
# Optional: Google OAuth client ID.
GOOGLE_CLIENT_ID=your_google_oauth_client_id
# Optional: Google OAuth client secret.
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# Optional: Google OAuth callback base URL. Add the derived callback URL to the Google OAuth client:
# - /callback
GOOGLE_APP_REDIRECT_URI_BASE=http://localhost:3001/api/apps/google/
# Required: secret used to encrypt persisted app credentials in production, and locally when you want credential encryption enabled.
APP_CREDENTIALS_SECRET=replace-with-a-strong-app-secret

# AWS deployment
# Optional: AWS CLI profile used by the provisioning and deployment scripts.
AWS_PROFILE=default
# Optional: AWS region for all deployment resources. Defaults to us-west-1.
AWS_REGION=us-west-1
# Optional: resource name prefix for AWS resources created by infra/aws-ec2.
AAA_RESOURCE_PREFIX=aaa
# Optional: deployment environment suffix used in AWS resource names.
ENVIRONMENT=prod
# Optional: EC2 instance type.
INSTANCE_TYPE=t4g.small
# Optional: EC2 root volume size in GiB.
ROOT_VOLUME_SIZE_GB=24
# Optional: persistent EBS data volume size in GiB.
DATA_VOLUME_SIZE_GB=30
# Optional: host data directory mounted into Postgres and Redis containers.
AAA_DATA_DIR=/opt/aaa/data
# Optional: public app URL override. If unset, deploy uses the EC2 public DNS over HTTP.
PUBLIC_BASE_URL=
# Optional: Caddy site address. Defaults to :80 for EC2 public DNS without a custom domain.
# Set this to your domain name if you later add DNS and want Caddy-managed HTTPS.
CADDY_SITE_ADDRESS=:80
