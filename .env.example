# Application
NODE_ENV=development
LOG_LEVEL=debug

# API Server
API_HOST=0.0.0.0
API_PORT=3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DEV_USER_ID=local-dev-user

# PostgreSQL
DATABASE_URL=postgresql://aaa:aaa_dev_password@localhost:5432/aaa
DATABASE_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379

# S3 / Object Storage
S3_BUCKET=aaa-uploads
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# MCP
MCP_SERVERS_CONFIG_PATH=./mcp-servers.json

# Connectors (placeholder — do not commit real credentials)
GITHUB_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
