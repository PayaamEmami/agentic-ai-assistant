{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@aaa/tool-providers": ["packages/tool-providers/src/index.ts"],
      "@aaa/ai": ["packages/ai/src/index.ts"],
      "@aaa/config": ["packages/config/src/index.ts"],
      "@aaa/knowledge-sources": ["packages/knowledge-sources/src/index.ts"],
      "@aaa/db": ["packages/db/src/index.ts"],
      "@aaa/mcp": ["packages/mcp/src/index.ts"],
      "@aaa/memory": ["packages/memory/src/index.ts"],
      "@aaa/observability": ["packages/observability/src/index.ts"],
      "@aaa/retrieval": ["packages/retrieval/src/index.ts"],
      "@aaa/shared": ["packages/shared/src/index.ts"]
    },
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "exclude": ["node_modules", "dist"]
}
